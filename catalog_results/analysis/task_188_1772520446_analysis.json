  "mindMap": "{\n  \"name\": \"大湾区大学成立大会深度解析\",\n  \"children\": [\n    {\n      \"name\": \"大会盛况与主要出席领导\",\n      \"children\": [\n        {\n          \"name\": \"十二月六日东莞松山湖校区隆重举行成立大会\",\n          \"collapse\": true,\n          \"children\": [\n            { \"name\": \"省委书记黄坤明出席调研\" },\n            { \"name\": \"省长孟凡丽出席大会并致辞\" },\n            { \"name\": \"省市校领导共同按下启动灯柱\" },\n            { \"name\": \"教育部批复同意设置大湾区大学\" }\n          ]\n        }\n      ]\n    },\n    {\n      \"name\": \"办学定位与核心战略目标\",\n      \"children\": [\n        {\n          \"name\": \"立足湾区面向全国辐射全球的公办普通高等学校\",\n          \"collapse\": true,\n          \"children\": [\n            { \"name\": \"高起点小而精研究型国际化\" },\n            { \"name\": \"理工为主经理强工基本特征\" },\n            { \"name\": \"服务粤港澳大湾区建设国家战略\" },\n            { \"name\": \"打造世界一流新型研究型大学\" }\n          ]\n        }\n      ]\n    },\n    {\n      \"name\": \"人才培养与重点学科建设\",\n      \"children\": [\n        {\n          \"name\": \"精准定位打造一流学科培育德智体美劳全面发展人才\",\n          \"collapse\": true,\n          \"children\": [\n            { \"name\": \"布局国家急需支撑产业学科\" },\n            { \"name\": \"推进新兴学科交叉学科建设\" },\n            { \"name\": \"善用人工智能新技术赋能教研\" },\n            { \"name\": \"探索港澳及国际联合培养人才模式\" }\n          ]\n        }\n      ]\n    },\n    {\n      \"name\": \"科研创新与一流师资集聚\",\n      \"children\": [\n        {\n          \"name\": \"集聚一流师资致力产出一流成果构建产学研深度融合\",\n          \"collapse\": true,\n          \"children\": [\n            { \"name\": \"开展柔性引才等多元化人才引进\" },\n            { \"name\": \"构建产学研深度融合创新生态\" },\n            { \"name\": \"开展原创性引领性科技攻关\" },\n            { \"name\": \"为发展新质生产力注入动力\" }\n          ]\n        }\n      ]\n    },\n    {\n      \"name\": \"校园设施与领导实地调研\",\n      \"children\": [\n        {\n          \"name\": \"深入查看校园整体环境与各项设施配置具体情况\",\n          \"collapse\": true,\n          \"children\": [\n            { \"name\": \"走进图书馆了解空间布局\" },\n            { \"name\": \"参观实验室专注操作实验器材\" },\n            { \"name\": \"现代化教学楼外观简约整洁\" },\n            { \"name\": \"省市加大办学投入提供服务保障\" }\n          ]\n        }\n      ]\n    }\n  ]\n}",
  "audioSegments": [
    {
      "startTime": 1.13,
      "endTime": 2.03,
      "audioText": "十二月六号，"
    },
    {
      "startTime": 2.25,
      "endTime": 6.63,
      "audioText": "大湾区大学成立大会在东莞松山湖校区举行。"
    },
    {
      "startTime": 7.21,
      "endTime": 11.83,
      "audioText": "省委书记黄坤明出席大会并实地调研办学情况。"
    },
    {
      "startTime": 12.37,
      "endTime": 13.39,
      "audioText": "省委副书记、"
    },
    {
      "startTime": 13.51,
      "endTime": 13.99,
      "audioText": "省长、"
    },
    {
      "startTime": 14.19,
      "endTime": 21.71,
      "audioText": "深圳市委书记孟凡丽出席大会并致辞黄坤明、"
    },
    {
      "startTime": 21.73,
      "endTime": 22.73,
      "audioText": "孟凡丽等部。"
    },
    {
      "startTime": 22.73,
      "endTime": 22.97,
      "audioText": "省、"
    },
    {
      "startTime": 22.99,
      "endTime": 25.21,
      "audioText": "市校领导共同按下启动灯柱，"
    },
    {
      "startTime": 25.49,
      "endTime": 27.735,
      "audioText": "标志着大湾区大学的正式成立。"
    },
    {
      "startTime": 28.42,
      "endTime": 31.62,
      "audioText": "黄坤明在调研中深入查看校园整体环境、"
    },
    {
      "startTime": 31.9,
      "endTime": 33.36,
      "audioText": "走进图书馆等区域，"
    },
    {
      "startTime": 33.58,
      "endTime": 37.14,
      "audioText": "详细了解学校空间布局和各项设施配置情况，"
    },
    {
      "startTime": 37.42,
      "endTime": 41.52,
      "audioText": "并听取学校负责人关于学校建设和办学情况的介绍。"
    },
    {
      "startTime": 42.2,
      "endTime": 47.26,
      "audioText": "黄坤明向学校教职员工和广大学生致以热烈祝贺和诚挚问候。"
    },
    {
      "startTime": 47.9,
      "endTime": 48.46,
      "audioText": "他指出，"
    },
    {
      "startTime": 48.76,
      "endTime": 50.32,
      "audioText": "创办设立大湾区大学，"
    },
    {
      "startTime": 50.5,
      "endTime": 53.98,
      "audioText": "对于更好落实粤港澳大湾区建设重大国家战略，"
    },
    {
      "startTime": 54.26,
      "endTime": 55.84,
      "audioText": "加快推进教育强省、"
    },
    {
      "startTime": 55.92,
      "endTime": 56.62,
      "audioText": "科技创新、"
    },
    {
      "startTime": 56.62,
      "endTime": 58.4,
      "audioText": "强省人才强省建设，"
    },
    {
      "startTime": 58.44,
      "endTime": 59.54,
      "audioText": "具有重要意义。"
    },
    {
      "startTime": 60.08,
      "endTime": 64.82,
      "audioText": "希望同志们深入学习贯彻习近平总书记关于教育的重要论述，"
    },
    {
      "startTime": 65.08,
      "endTime": 68.42,
      "audioText": "以及对广东系列重要讲话和重要指示精神，"
    },
    {
      "startTime": 68.84,
      "endTime": 70.1,
      "audioText": "增强为党育人、"
    },
    {
      "startTime": 70.2,
      "endTime": 71.76,
      "audioText": "为国育才的政治自觉，"
    },
    {
      "startTime": 72.2,
      "endTime": 75.3,
      "audioText": "坚持扎根广东立足湾区胸怀国家，"
    },
    {
      "startTime": 75.4,
      "endTime": 76.2,
      "audioText": "面向世界、"
    },
    {
      "startTime": 76.62,
      "endTime": 78.42,
      "audioText": "希照高起点小而精，"
    },
    {
      "startTime": 78.52,
      "endTime": 81.42,
      "audioText": "研究型国际化办学发展高标准、"
    },
    {
      "startTime": 81.5,
      "endTime": 81.98,
      "audioText": "高质量，"
    },
    {
      "startTime": 81.98,
      "endTime": 83.46,
      "audioText": "推进学校建设发展，"
    },
    {
      "startTime": 83.82,
      "endTime": 85.74,
      "audioText": "加快打造具有湾区特色、"
    },
    {
      "startTime": 85.9,
      "endTime": 88.105,
      "audioText": "世界一流的国型研究型大学。"
    },
    {
      "startTime": 89.02,
      "endTime": 91.0,
      "audioText": "要坚持社会主义办学方向，"
    },
    {
      "startTime": 91.28,
      "endTime": 93.1,
      "audioText": "全面贯彻党的教育方针，"
    },
    {
      "startTime": 93.46,
      "endTime": 95.74,
      "audioText": "牢牢把握立德树人根本任务，"
    },
    {
      "startTime": 95.96,
      "endTime": 97.5,
      "audioText": "统筹推进学校教学、"
    },
    {
      "startTime": 97.5,
      "endTime": 98.6,
      "audioText": "科研各项工作，"
    },
    {
      "startTime": 98.9,
      "endTime": 103.34,
      "audioText": "培养德智体美劳全面发展的社会主义建设者和接班人。"
    },
    {
      "startTime": 104.06,
      "endTime": 105.12,
      "audioText": "要精准定位，"
    },
    {
      "startTime": 105.12,
      "endTime": 106.2,
      "audioText": "打造一流学科，"
    },
    {
      "startTime": 106.5,
      "endTime": 114.64,
      "audioText": "形焦做精做强理工科特色布局一批国家急需支撑产业转型升级和区域发展的学科因地制宜，"
    },
    {
      "startTime": 114.66,
      "endTime": 117.04,
      "audioText": "推进新兴学科交叉学科建设，"
    },
    {
      "startTime": 117.48,
      "endTime": 118.32,
      "audioText": "形成优势，"
    },
    {
      "startTime": 118.32,
      "endTime": 120.425,
      "audioText": "突出特色鲜明的学科体系。"
    },
    {
      "startTime": 121.21,
      "endTime": 122.27,
      "audioText": "要创新方法，"
    },
    {
      "startTime": 122.29,
      "endTime": 123.39,
      "audioText": "培育一流人才，"
    },
    {
      "startTime": 123.71,
      "endTime": 125.25,
      "audioText": "抓好教学质量管理，"
    },
    {
      "startTime": 125.49,
      "endTime": 127.29,
      "audioText": "注重加强对科学精神、"
    },
    {
      "startTime": 127.41,
      "endTime": 128.19,
      "audioText": "创新思维、"
    },
    {
      "startTime": 128.27,
      "endTime": 129.41,
      "audioText": "动手能力的塑造，"
    },
    {
      "startTime": 129.41,
      "endTime": 132.11,
      "audioText": "培养善用人工智能等新技术、"
    },
    {
      "startTime": 132.11,
      "endTime": 133.87,
      "audioText": "新手段赋能教研工作，"
    },
    {
      "startTime": 134.37,
      "endTime": 135.55,
      "audioText": "积极与有关部门、"
    },
    {
      "startTime": 135.59,
      "endTime": 136.33,
      "audioText": "科研院所、"
    },
    {
      "startTime": 136.47,
      "endTime": 137.29,
      "audioText": "行业企业、"
    },
    {
      "startTime": 137.43,
      "endTime": 141.13,
      "audioText": "港澳及国际优质高校探索联合培养人才模式，"
    },
    {
      "startTime": 141.51,
      "endTime": 145.55,
      "audioText": "努力造就更多适应现代化建设需要的拔尖创新人才。"
    },
    {
      "startTime": 146.35,
      "endTime": 147.41,
      "audioText": "要创造条件，"
    },
    {
      "startTime": 147.45,
      "endTime": 148.61,
      "audioText": "集聚一流师资，"
    },
    {
      "startTime": 148.91,
      "endTime": 151.73,
      "audioText": "注重以重大创新任务和一流科研平台，"
    },
    {
      "startTime": 151.81,
      "endTime": 153.49,
      "audioText": "引才聚才创新，"
    },
    {
      "startTime": 153.49,
      "endTime": 156.51,
      "audioText": "开展柔性引才等多元化人才引进方式，"
    },
    {
      "startTime": 156.89,
      "endTime": 158.79,
      "audioText": "抓好人才发展环境建设，"
    },
    {
      "startTime": 159.13,
      "endTime": 161.01,
      "audioText": "加快打造一支师德高尚、"
    },
    {
      "startTime": 161.15,
      "endTime": 161.91,
      "audioText": "业务精湛、"
    },
    {
      "startTime": 162.07,
      "endTime": 162.87,
      "audioText": "结构合理、"
    },
    {
      "startTime": 162.99,
      "endTime": 165.805,
      "audioText": "充满活力的高素质专业化教师队伍。"
    },
    {
      "startTime": 166.56,
      "endTime": 168.3,
      "audioText": "要致力产出一流成果，"
    },
    {
      "startTime": 168.56,
      "endTime": 169.32,
      "audioText": "广泛链接。"
    },
    {
      "startTime": 169.32,
      "endTime": 171.36,
      "audioText": "湾区优质科研和产业资源，"
    },
    {
      "startTime": 171.64,
      "endTime": 173.86,
      "audioText": "着力构建产学研深度融合、"
    },
    {
      "startTime": 173.88,
      "endTime": 174.64,
      "audioText": "创新生态，"
    },
    {
      "startTime": 175.06,
      "endTime": 177.86,
      "audioText": "聚焦科技前沿领域和产业发展急需，"
    },
    {
      "startTime": 178.24,
      "endTime": 179.72,
      "audioText": "深入开展原创性、"
    },
    {
      "startTime": 179.76,
      "endTime": 181.98,
      "audioText": "引领性科技攻关和成果转化，"
    },
    {
      "startTime": 182.34,
      "endTime": 183.96,
      "audioText": "为发展新智生产力，"
    },
    {
      "startTime": 184.0,
      "endTime": 185.275,
      "audioText": "注入强大动力。"
    },
    {
      "startTime": 185.96,
      "endTime": 189.32,
      "audioText": "省有关单位和东莞市要全力做好服务工作，"
    },
    {
      "startTime": 189.62,
      "endTime": 191.06,
      "audioText": "持续加大办学投入，"
    },
    {
      "startTime": 191.28,
      "endTime": 192.46,
      "audioText": "关心师生工作、"
    },
    {
      "startTime": 192.46,
      "endTime": 193.2,
      "audioText": "学习生活，"
    },
    {
      "startTime": 193.54,
      "endTime": 196.18,
      "audioText": "为学校建设发展创造更好条件，"
    },
    {
      "startTime": 196.3,
      "endTime": 197.615,
      "audioText": "提供有力保障。"
    },
    {
      "startTime": 198.66,
      "endTime": 200.64,
      "audioText": "孟繁丽在致辞中代表省委、"
    },
    {
      "startTime": 200.64,
      "endTime": 203.98,
      "audioText": "省政府对大湾区大学的成立表示热烈祝贺，"
    },
    {
      "startTime": 204.64,
      "endTime": 208.48,
      "audioText": "向教育部向在整个筹备建设和批准设立过程中，"
    },
    {
      "startTime": 208.48,
      "endTime": 210.4,
      "audioText": "辛勤付出和给予关心、"
    },
    {
      "startTime": 210.48,
      "endTime": 212.98,
      "audioText": "支持帮助的各方面表示衷心感谢，"
    },
    {
      "startTime": 213.08,
      "endTime": 214.3,
      "audioText": "致以崇高敬意。"
    },
    {
      "startTime": 214.84,
      "endTime": 215.24,
      "audioText": "他说，"
    },
    {
      "startTime": 215.7,
      "endTime": 217.52,
      "audioText": "习近平总书记深刻指出，"
    },
    {
      "startTime": 217.76,
      "endTime": 222.68,
      "audioText": "教育科技人才是全面建设社会主义现代化国家的基础性、"
    },
    {
      "startTime": 222.72,
      "endTime": 223.64,
      "audioText": "战略性支撑。"
    },
    {
      "startTime": 224.12,
      "endTime": 228.08,
      "audioText": "寄望广东在推进中国式现代化建设中走在前列。"
    },
    {
      "startTime": 228.44,
      "endTime": 232.2,
      "audioText": "粤港澳大湾区建设成为一点两地光荣的任务。"
    },
    {
      "startTime": 232.28,
      "endTime": 234.9,
      "audioText": "伟大的实践需要一大批优秀人才，"
    },
    {
      "startTime": 235.26,
      "endTime": 237.3,
      "audioText": "需要科技引领和创新驱撑。"
    },
    {
      "startTime": 237.7,
      "endTime": 239.88,
      "audioText": "这正是大湾区大学的使命所在。"
    },
    {
      "startTime": 240.3,
      "endTime": 243.88,
      "audioText": "希望大湾区大学锚定新型研究型大学的总定位，"
    },
    {
      "startTime": 244.12,
      "endTime": 245.56,
      "audioText": "按照批复规划要求，"
    },
    {
      "startTime": 245.92,
      "endTime": 247.06,
      "audioText": "集聚一流师资，"
    },
    {
      "startTime": 247.18,
      "endTime": 248.26,
      "audioText": "打造一流学科、"
    },
    {
      "startTime": 248.42,
      "endTime": 249.58,
      "audioText": "培养一流人才，"
    },
    {
      "startTime": 249.76,
      "endTime": 250.96,
      "audioText": "培养一流成果，"
    },
    {
      "startTime": 251.48,
      "endTime": 254.5,
      "audioText": "紧紧围绕国家战略和经济社会发展需要，"
    },
    {
      "startTime": 254.8,
      "endTime": 260.505,
      "audioText": "为建设富有活力和国际竞争力的一流湾区和世界级城市群贡献力量，"
    },
    {
      "startTime": 261.18,
      "endTime": 262.64,
      "audioText": "切实加强党的领导，"
    },
    {
      "startTime": 262.86,
      "endTime": 264.72,
      "audioText": "落实立德树人根本任务，"
    },
    {
      "startTime": 264.94,
      "endTime": 270.83,
      "audioText": "培养德智体美劳全面发展的社会主义建设者和接班人大会，"
    },
    {
      "startTime": 270.83,
      "endTime": 271.77,
      "audioText": "由省委常委、"
    },
    {
      "startTime": 271.81,
      "endTime": 277.69,
      "audioText": "副省长张国志主持会上宣读了教育部关于同意设置大湾区大学的批复。"
    },
    {
      "startTime": 278.229,
      "endTime": 279.85,
      "audioText": "大湾区大学创校校长、"
    },
    {
      "startTime": 279.93,
      "endTime": 281.89,
      "audioText": "东莞市主要负责同志致辞。"
    },
    {
      "startTime": 282.65,
      "endTime": 283.91,
      "audioText": "省领导王希冯、"
    },
    {
      "startTime": 283.91,
      "endTime": 284.33,
      "audioText": "中华、"
    },
    {
      "startTime": 284.49,
      "endTime": 285.05,
      "audioText": "唐一峰，"
    },
    {
      "startTime": 285.45,
      "endTime": 287.45,
      "audioText": "中山大学党委书记刘成功，"
    },
    {
      "startTime": 287.77,
      "endTime": 290.81,
      "audioText": "香港澳门特区政府有关代表以及院士、"
    },
    {
      "startTime": 290.81,
      "endTime": 291.21,
      "audioText": "专家、"
    },
    {
      "startTime": 291.35,
      "endTime": 292.11,
      "audioText": "相关高校、"
    },
    {
      "startTime": 292.21,
      "endTime": 292.89,
      "audioText": "科研院所、"
    },
    {
      "startTime": 293.01,
      "endTime": 294.775,
      "audioText": "企业等代表出席大会。"
    },
    {
      "startTime": 295.64,
      "endTime": 296.14,
      "audioText": "据悉，"
    },
    {
      "startTime": 296.36,
      "endTime": 299.18,
      "audioText": "大湾区大学是一所经教育部批准设立，"
    },
    {
      "startTime": 299.38,
      "endTime": 301.16,
      "audioText": "由广东省人民政府举办。"
    },
    {
      "startTime": 301.32,
      "endTime": 303.2,
      "audioText": "东莞市投入保障的公办、"
    },
    {
      "startTime": 303.22,
      "endTime": 307.86,
      "audioText": "普通高等学校学校将立足湾区面向全国辐射全球，"
    },
    {
      "startTime": 308.3,
      "endTime": 309.54,
      "audioText": "坚持理工为主、"
    },
    {
      "startTime": 309.66,
      "endTime": 311.16,
      "audioText": "经理强工基本特征，"
    },
    {
      "startTime": 311.56,
      "endTime": 312.66,
      "audioText": "以基础扎实、"
    },
    {
      "startTime": 312.76,
      "endTime": 313.56,
      "audioText": "视野开阔、"
    },
    {
      "startTime": 313.7,
      "endTime": 314.52,
      "audioText": "知行合一、"
    },
    {
      "startTime": 314.64,
      "endTime": 316.72,
      "audioText": "融会贯通为人才培养目标，"
    },
    {
      "startTime": 317.1,
      "endTime": 319.88,
      "audioText": "以大学家模式为办学特色培养，"
    },
    {
      "startTime": 319.88,
      "endTime": 324.32,
      "audioText": "具备解决复杂问题和创新实践能力的高素质研究型人才，"
    },
    {
      "startTime": 324.74,
      "endTime": 330.44,
      "audioText": "致力于建设成为一所国际水准开放包容湾区特色的新型研究型人才。"
    },
    {
      "startTime": 331.14,
      "endTime": 332.865,
      "audioText": "广东台记者张科报道。"
    }
